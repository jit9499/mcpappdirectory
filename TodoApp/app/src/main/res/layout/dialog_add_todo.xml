<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Title input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_title"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:imeOptions="actionDone" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Stars label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/label_priority"
        android:textColor="@color/label_text"
        android:textSize="13sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08" />

    <!-- Star picker row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView android:id="@+id/dialogStar1"
            android:layout_width="36dp" android:layout_height="36dp"
            android:padding="2dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Star 1" />
        <ImageView android:id="@+id/dialogStar2"
            android:layout_width="36dp" android:layout_height="36dp"
            android:padding="2dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Star 2" />
        <ImageView android:id="@+id/dialogStar3"
            android:layout_width="36dp" android:layout_height="36dp"
            android:padding="2dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Star 3" />
        <ImageView android:id="@+id/dialogStar4"
            android:layout_width="36dp" android:layout_height="36dp"
            android:padding="2dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Star 4" />
        <ImageView android:id="@+id/dialogStar5"
            android:layout_width="36dp" android:layout_height="36dp"
            android:padding="2dp"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Star 5" />

    </LinearLayout>

    <!-- Duration label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/label_duration"
        android:textColor="@color/label_text"
        android:textSize="13sp"
        android:textAllCaps="true"
        android:letterSpacing="0.08" />

    <!-- Duration NumberPicker -->
    <NumberPicker
        android:id="@+id/pickerDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp" />

</LinearLayout>
