<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/board_surface">

    <!-- Nameplate layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Accent banner strip at top -->
        <View
            android:id="@+id/viewAccent"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/board_amber" />

        <!-- Board body -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Drag handle -->
            <ImageView
                android:id="@+id/dragHandle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_drag_handle"
                android:contentDescription="Drag to reorder"
                android:alpha="0.4" />

            <!-- Title (main nameplate text) -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/dragHandle"
                android:layout_toStartOf="@+id/starRow"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end"
                android:letterSpacing="0.04"
                android:textColor="@color/board_amber" />

            <!-- Star row on the right -->
            <LinearLayout
                android:id="@+id/starRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView android:id="@+id/star1"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:contentDescription="Star 1"
                    android:padding="1dp" />
                <ImageView android:id="@+id/star2"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:contentDescription="Star 2"
                    android:padding="1dp" />
                <ImageView android:id="@+id/star3"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:contentDescription="Star 3"
                    android:padding="1dp" />
                <ImageView android:id="@+id/star4"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:contentDescription="Star 4"
                    android:padding="1dp" />
                <ImageView android:id="@+id/star5"
                    android:layout_width="22dp" android:layout_height="22dp"
                    android:contentDescription="Star 5"
                    android:padding="1dp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:background="@color/board_divider" />

        <!-- Footer: duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="50dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:alpha="0.5"
                android:contentDescription="Duration" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="13sp"
                android:textColor="@color/duration_text"
                android:alpha="0.75" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
